    <!-- Sobre -->
    <string name="app_version">Versão 1.0 — 2026</string>
    <string name="about_section_app">Sobre o PlantGuide</string>
    <string name="about_description">O PlantGuide é um aplicativo de guia de plantas desenvolvido como projeto final da disciplina de Desenvolvimento Mobile II da Universidade de Passo Fundo (UPF). O app reúne informações detalhadas sobre espécies de plantas, incluindo nível de luz, frequência de rega, ambiente ideal, cuidados básicos e indicação de toxicidade para animais de estimação.</string>
    <string name="about_section_tech">Tecnologias Utilizadas</string>
    <string name="about_technologies">• Kotlin\n• Android Studio\n• Room (SQLite) — persistência local\n• ViewModel + LiveData\n• CameraX + OpenRouter API\n• Material Design 3\n• ViewBinding\n• RecyclerView com DiffUtil\n• Navigation Drawer</string>
    <string name="about_section_discipline">Disciplina</string>
    <string name="about_discipline_info">ADS — Desenvolvimento Mobile II\nSemestre: 2026/1\nProfessores: Diego A. Lusa e Jaqson Dalbosco\nUniversidade de Passo Fundo — UPF</string>

